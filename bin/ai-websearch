#!/bin/sh

check_and_setup_key() {
    KEY="${OPENCODE_API_KEY:-}"
    if [ -n "$KEY" ] && [ "$KEY" != "your-api-key" ]; then
        return 0
    fi
    
    echo "❌ ยังไม่ได้ตั้ง API key"
    echo "เปิดลิงก์สมัคร: https://opencode.ai/settings/api"
    am start -a android.intent.action.VIEW -d "https://opencode.ai/settings/api" 2>/dev/null
    
    echo -n "ใส่ API key: "
    read -r KEY
    
    if [ -n "$KEY" ]; then
        echo "export OPENCODE_API_KEY='$KEY'" >> ~/.zshrc
        export OPENCODE_API_KEY="$KEY"
        echo "✅ บันทึกแล้ว"
    else
        echo "❌ ต้องใส่ API key"
        exit 1
    fi
}

check_and_setup_key

NUM_RESULTS="${1:-8}"
shift

if [ $# -eq 0 ]; then
    echo "ใช้: ai-websearch <จำนวน> <คำค้น>"
    exit 1
fi

QUERY="$*"

echo "🔍 ค้นหา: $QUERY"
echo "─────────────────────"

RESPONSE=$(curl -s -X POST "https://opencode.ai/api/v1/websearch" \
    -H "Authorization: Bearer $OPENCODE_API_KEY" \
    -H "Content-Type: application/json" \
    -d "{
        \"query\": \"$QUERY\",
        \"num_results\": $NUM_RESULTS
    }")

echo "$RESPONSE" | jq -r '.results[] | "[\(.title)](\(.url))\n\(.description)\n"' 2>/dev/null || \
    echo "$RESPONSE"