#!/bin/sh

MSG="$1"

if [ -z "$MSG" ]; then
    echo "ใช้: gh-push <commit-message>"
    exit 1
fi

git add -A
git commit -m "$MSG"

BRANCH=$(git branch --show-current)
REMOTE=$(git remote get-url origin 2>/dev/null || echo "")

if [ -z "$REMOTE" ]; then
    echo "❌ ไม่มี remote origin"
    echo "ใช้: git remote add origin <url>"
    exit 1
fi

git push -u origin "$BRANCH"
echo "✅ Push เสร็จ!"