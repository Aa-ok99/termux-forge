#!/data/data/com.termux/files/home/bin/bash

NEW_PROJECT() {
    local TEMPLATE="${1:-basic}"
    local NAME="$2"
    
    if [[ -z "$NAME" ]]; then
        echo "ใช้: new-project <template> <ชื่อโปรเจ็ค>"
        echo "Templates: basic, node, python, react, go, rust"
        return 1
    fi
    
    mkdir -p "$NAME"
    cd "$NAME"
    
    case "$TEMPLATE" in
        node)
            npm init -y
            ;;
        python)
            echo '#!/usr/bin/env python3' > main.py
            ;;
        react)
            npx create-react-app "$NAME" 2>/dev/null || \
                echo '{"name":"'$NAME'","version":"1.0.0"}' > package.json
            ;;
        go)
            go mod init "$NAME"
            ;;
        rust)
            cargo init --bin "$NAME"
            ;;
        *)
            echo "# $NAME" > README.md
            ;;
    esac
    
    git init
    echo "node_modules/" > .gitignore
    echo "✅ สร้าง $NAME เสร็จ"
}

NEW_PROJECT "$@"