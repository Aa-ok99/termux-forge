#!/bin/sh

EXT="${1:-js}"
DIR="${2:-.}"

echo "🔍 ตรวจ dead code..."
echo "─────────────────────"

case "$EXT" in
    js|ts|jsx|tsx)
        grep -rn "function " "$DIR" --include="*.$EXT" | head -20
        grep -rn "const " "$DIR" --include="*.$EXT" | head -20
        ;;
    py)
        grep -rn "def " "$DIR" --include="*.py" | head -20
        ;;
    go)
        grep -rn "func " "$DIR" --include="*.go" | head -20
        ;;
    rs)
        grep -rn "fn " "$DIR" --include="*.rs" | head -20
        ;;
    *)
        echo "รองรับ: js, ts, py, go, rs"
        exit 1
        ;;
esac

echo "─────────────────────"
echo "✅ เสร็จ"