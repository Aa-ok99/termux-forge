#!/bin/sh

check_and_setup_key() {
    KEY="${OPENCODE_API_KEY:-}"
    if [ -n "$KEY" ] && [ "$KEY" != "your-api-key" ]; then
        return 0
    fi
    
    echo "❌ ยังไม่ได้ตั้ง API key"
    echo "เปิดลิงก์สมัคร: https://opencode.ai/settings/api"
    am start -a android.intent.action.VIEW -d "https://opencode.ai/settings/api" 2>/dev/null
    
    echo -n "ใส่ API key: "
    read -r KEY
    
    if [ -n "$KEY" ]; then
        echo "export OPENCODE_API_KEY='$KEY'" >> ~/.zshrc
        export OPENCODE_API_KEY="$KEY"
        echo "✅ บันทึกแล้ว"
    else
        echo "❌ ต้องใส่ API key"
        exit 1
    fi
}

check_and_setup_key

MODEL="${OPENCODE_MODEL:-opencode/minimax-m2.5-free}"

echo "🤖 AI CLI - พิมพ์ 'exit' ออก"
echo "─────────────────────"

CONV_HISTORY="[]"

while true; do
    echo -n -e "\n\033[1;32mคุณ>\033[0m "
    read -r PROMPT
    
    [ "$PROMPT" = "exit" ] && break
    [ -z "$PROMPT" ] && continue
    
    CONV_HISTORY=$(echo "$CONV_HISTORY" | jq --arg p "$PROMPT" '. + [{"role":"user","content":$p}]')
    
    RESPONSE=$(curl -s -X POST "https://opencode.ai/api/v1/chat" \
        -H "Authorization: Bearer $OPENCODE_API_KEY" \
        -H "Content-Type: application/json" \
        -d "{
            \"model\": \"$MODEL\",
            \"messages\": $(echo "$CONV_HISTORY")
        }")
    
    ANSWER=$(echo "$RESPONSE" | jq -r '.choices[0].message.content // .error.message')
    echo -e "\n\033[1;34mAI>\033[0m $ANSWER"
    
    CONV_HISTORY=$(echo "$CONV_HISTORY" | jq --arg a "$ANSWER" '. + [{"role":"assistant","content":$a}]')
done